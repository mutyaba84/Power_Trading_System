import os, json
from fastapi import FastAPI

app = FastAPI(title="Power Trading System API")

AI_STATE_DIR = os.getenv("AI_STORAGE_PATH", "external_memory/ai_state")

@app.get("/ai/paper-state")
def get_paper_state():
    path = os.path.join(AI_STATE_DIR, "paper_trading_state.json")
    if not os.path.exists(path):
        return {}
    try:
        with open(path, "r") as f:
            return json.load(f)
    except Exception as e:
        print(f"Paper trading state read error: {e}")
        return {}
